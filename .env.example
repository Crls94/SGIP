# SGIP - plantilla de entorno productivo/cliente
# Copiar a .env o al gestor de variables del servidor. No commitear valores reales.
#



# Backend Spring Boot
SPRING_PROFILES_ACTIVE=prod
DB_URL=jdbc:postgresql://localhost:5432/metroDB_cliente
DB_USER=sgip_user
DB_PASSWORD=cambiar_password_seguro
JWT_SECRET=cambiar_clave_larga_segura_minimo_32_caracteres
JWT_EXPIRATION=3600000
REPORTES_DIR=/opt/sgip/reportes

# Correo SMTP opcional
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@metroica.pe
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# IA predictiva en produccion
IA_ENV=prod
IA_API_URL=https://dominio-cliente/api/v1/inteligencia/datos-entrenamiento
IA_PREDICCIONES_URL=https://dominio-cliente/api/v1/inteligencia/predicciones
IA_LOGIN_URL=https://dominio-cliente/api/v1/auth/login
IA_API_TOKEN=cambiar_token_jwt_admin_o_gerente

#run ia produc con nuevo token - añadiendo .env
#bash -lc 'set -a; source .env; set +a; source venv/bin/activate; streamlit run ia_prediccion.py'
